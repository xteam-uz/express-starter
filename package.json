{
  "name": "express-starter",
  "version": "2.0.0",
  "description": "A simple, production-minded Express 5 + TypeScript starter kit.",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "dev": "tsx --watch --env-file=.env src/index.ts",
    "build": "tsc && tsc-alias",
    "start": "node --env-file=.env dist/index.js",
    "test": "tsx --test test/*.test.ts",
    "test:watch": "tsx --test --watch test/*.test.ts",
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "express",
    "node.js",
    "typescript",
    "starter-kit",
    "api"
  ],
  "author": "Mirsoli Mirsultonov<mirrrrrr@yahoo.com>",
  "license": "ISC",
  "packageManager": "pnpm@10.10.0",
  "dependencies": {
    "express": "^5.1.0",
    "mongoose": "^8.18.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.1",
    "@types/node": "^22.15.16",
    "tsc-alias": "^1.8.16",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
